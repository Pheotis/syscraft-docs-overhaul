---
import { CollectionEntry, getCollection } from 'astro:content';
import MainLayout from '../../layouts/HostLayout.astro';

export async function getStaticPaths() {
	const hosting = await getCollection('hosting');
	return hosting.map((entry) => ({
		params: {
			slug: entry.slug,
		},
		props: entry,
	}));
}
type Props = CollectionEntry<'hosting'>;

const post = Astro.props;
const { Content, headings } = await post.render();
---

<MainLayout headings={headings} {...post.data}>
	<Content />
</MainLayout>
